COMPOSE_FILE=docker-compose.yml:mongo/docker-compose.yml:openwebui/docker-compose.yml
COMPOSE_PROJECT_NAME=deploy

# TODO: Configure the deployment
PROJECT_NAME=mdcs
IMAGE_NAME=mdcs
IMAGE_VERSION=custom
HOSTNAME=10.0.1.50
SERVER_URI=http://10.0.1.50
ALLOWED_HOSTS=*
SERVER_NAME=MDCS
WEB_SERVER=runserver
SERVER_CONF=default
SETTINGS=dev_settings
# FOR UWSGI_AUTORELOAD for the Django app
PROCESSES=1
THREADS=4
UWSGI_AUTORELOAD=1
START_CELERY=true

# TODO: Set values for the databases configuration and credentials
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASS=something
MONGO_USER=cdcs_user
MONGO_PASS=something
MONGO_DB=cdcs
POSTGRES_USER=cdcs_user
POSTGRES_PASS=something
POSTGRES_DB=cdcs
REDIS_PASS=something
DJANGO_SECRET_KEY=something

DEV_HOST_PORT=80

# TODO: Set versions for the components of the CDCS stack
MONGO_VERSION=7.0
REDIS_VERSION=7
POSTGRES_VERSION=16
NGINX_VERSION=1.27

# TODO: Set port mapping
NGINX_PORT_80=80
NGINX_PORT_443=443

# For OpenWebUI
OPENWEBUI_IMAGE_NAME=openwebui_audit
OPENWEBUI_IMAGE_VERSION=latest
OPENWEBUI_PORT=3000
OLLAMA_IMAGE_NAME=ollama/ollama
OLLAMA_IMAGE_VERSION=latest
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://curator_ollama:11434
# Leave AUDIT_SECRET empty to disable audit logging
AUDIT_SECRET=
AUDIT_LOG_PATH=/app/backend/data/audit/audit.log
AUDIT_LOG_DIR=./openwebui/audit_logs
